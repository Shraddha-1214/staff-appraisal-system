<div class="container" style="margin-top: 30px;">
    <div class="card-panel white" style="border-left: 8px solid #003366; border-radius: 8px;">
        <h4 class="blue-text text-darken-4" style="font-weight: bold; margin-top: 0;">Appraisal Dashboard: {{year}}</h4>
        <p style="font-size: 1.1rem;">
            Current Status: 
            <span class="chip {{#if_eq status 'Draft'}}blue lighten-4 blue-text{{else}}green lighten-4 green-text{{/if_eq}} darken-4" style="font-weight: bold;">
                {{status}}
            </span>
        </p>
    </div>

    <div class="row" style="margin-top: 40px;">
        <div class="col s12">
            <div class="card hoverable z-depth-2" style="border-radius: 12px; overflow: hidden;">
                <div class="card-content">
                    <span class="card-title" style="color: #003366; font-weight: bold; display: flex; align-items: center;">
                        <i class="material-icons" style="margin-right: 10px; font-size: 2rem;">assignment</i>
                        Appraisal Form
                    </span>
                    <p class="grey-text text-darken-2" style="font-size: 1.1rem; margin: 15px 0;">
                        Please fill in all sections including Teaching Process, Student Feedback, and Departmental Activities. 
                        You can save your progress and return to complete the form later.
                    </p>
                    
                    {{#if_eq status 'Draft'}}
                        <div class="chip green lighten-5 green-text text-darken-3">
                            <i class="material-icons left" style="font-size: 1.2rem;">edit</i>
                            Currently Editable
                        </div>
                    {{else}}
                        <div class="chip red lighten-5 red-text text-darken-3">
                            <i class="material-icons left" style="font-size: 1.2rem;">lock</i>
                            Form Submitted
                        </div>
                    {{/if_eq}}
                </div>
                
                <div class="card-action grey lighten-4 center-align">
                    <a href="/appraisal/form" class="btn-large indigo darken-4 waves-effect waves-light" style="width: 100%; max-width: 400px; border-radius: 25px; font-weight: bold;">
                        <i class="material-icons left">launch</i> 
                        {{#if_eq status 'Draft'}}START / CONTINUE FILLING FORM{{else}}VIEW FORM{{/if_eq}}
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-content">
        <span class="card-title">Appraisal Status: 
            <span class="chip {{#if_eq status 'Submitted'}}orange white-text{{/if_eq}} {{#if_eq status 'Reviewed'}}green white-text{{/if_eq}}">
                {{status}}
            </span>
        </span>
        
        {{#if_eq status 'Draft'}}
            <p>Your appraisal is still in progress. Please complete all sections and click Final Submit.</p>
        {{else}}
            <p>Your appraisal has been sent for review. You can no longer edit it.</p>
        {{/if_eq}}
    </div>
</div>