                    <thead><tr><th>Details of Material</th><th>Remark</th><th>Action</th></tr></thead>
                    <tbody>
                        {{#each appraisal.elearningMaterial}}
                        <tr>
                            <td><input type="text" name="elearningMaterial[{{@index}}][details]" value="{{this.details}}" class="table-input"></td>
                            <td><input type="text" name="elearningMaterial[{{@index}}][remark]" value="{{this.remark}}" class="table-input"></td>
                            <td><i class="material-icons red-text pointer" onclick="this.closest('tr').remove()">delete</i></td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                <div class="right-align" style="margin-top:10px;"><span class="add-btn" onclick="addRow('table4_2')">+ Add Row</span> <button type="submit" class="btn save-btn ml-2">Save 4.2</button></div>
            </form>
        </div>
    </div>

    <h5 class="part-divider">Part V: Other Relevant Information</h5>
    
    <div class="card section-card">
        <div class="form-header">5.1 Other Credentials / Awards</div>
        <div class="card-content">
            <form action="/appraisal/save-other-info" method="POST">
                <table id="table5_1" class="highlight">
                    <thead><tr><th>Details (Year, Value etc)</th><th>Action</th></tr></thead>
                    <tbody>
                        {{#each appraisal.otherInfo}}
                        <tr>
                            <td><input type="text" name="otherInfo[{{@index}}][details]" value="{{this.details}}" class="table-input"></td>
                            <td><i class="material-icons red-text pointer" onclick="this.closest('tr').remove()">delete</i></td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                <div class="right-align" style="margin-top:10px;"><span class="add-btn" onclick="addRow('table5_1')">+ Add Row</span> <button type="submit" class="btn save-btn ml-2">Save Part V</button></div>
            </form>
        </div>
    </div>

    <h5 class="part-divider">Part VI: List of Enclosures</h5>
    <div class="card section-card">
        <div class="form-header">Upload All Certificates & Papers</div>
        <div class="card-content">
            <form action="/appraisal/save-enclosures" method="POST" enctype="multipart/form-data">
                <table id="enclosureTable" class="highlight">
                    <thead><tr><th style="width:10%">Encl No</th><th style="width:40%">Description</th><th style="width:40%">File (PDF/JPG)</th><th>Action</th></tr></thead>
                    <tbody>
                        {{#each appraisal.generalEnclosures}}
                        <tr>
                            <td><input type="text" name="enclosureNos[]" value="{{this.enclosureNo}}" class="table-input"></td>
                            <td><input type="text" name="enclosureDescriptions[]" value="{{this.description}}" class="table-input"></td>
                            <td>
                                {{#if this.fileUrl}}
                                    <input type="hidden" name="existingUrls[]" value="{{this.fileUrl}}">
                                    <a href="{{this.fileUrl}}" target="_blank" class="indigo-text"><b>View Attached File</b></a>
                                {{else}}
                                    <input type="file" name="proofDocument" class="table-input" style="border:none;">
                                {{/if}}
                            </td>
                            <td><i class="material-icons red-text pointer" onclick="this.closest('tr').remove()">delete</i></td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                <div class="right-align" style="margin-top:20px;"><span class="add-btn" onclick="addRow('enclosureTable')">+ Add File Slot</span> <button type="submit" class="btn save-btn ml-2">Upload All</button></div>
            </form>
        </div>
    </div>
</div>

<div class="card section-card red lighten-5" style="border: 2px solid #d32f2f !important; margin-top: 50px;">
    <div class="card-content center-align">
        <h5 class="red-text text-darken-2" style="font-weight: 700;">Final Submission</h5>
        <p>Before submitting, please ensure all parts (I-V) are saved and all necessary documents are uploaded in Part VI[cite: 58]. Once submitted, you will not be able to edit the form unless the HOD sends it back.</p>
        
        <form action="/appraisal/final-submit" method="POST" style="margin-top: 20px;">
            <button type="submit" class="btn-large red darken-2 waves-effect waves-light" 
                onclick="return confirm('Are you sure you want to submit your appraisal? This will send it to the HOD for review.')">
                <i class="material-icons left">send</i> Final Submit to HOD
            </button>
        </form>
    </div>
</div>

