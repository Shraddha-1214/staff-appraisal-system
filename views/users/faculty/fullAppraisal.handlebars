<style>
    :root { --pbas-primary: #1a237e; --pbas-border: #dee2e6; }
    .section-card { border-radius: 8px; margin-bottom: 35px; border: 1px solid var(--pbas-border); box-shadow: none; }
    .form-header { background: var(--pbas-primary); color: white; padding: 12px 20px; border-radius: 7px 7px 0 0; font-size: 0.95rem; }
    .table-input { border: 1px solid #ccc !important; border-radius: 3px !important; padding: 4px 8px !important; height: 30px !important; font-size: 0.85rem !important; width: 100%; }
    th { background: #f8f9fa; color: #37474f; font-size: 0.75rem; text-transform: uppercase; border-bottom: 2px solid var(--pbas-border) !important; padding: 10px 8px !important; }
    .part-divider { margin: 50px 0 25px 0; border-left: 4px solid var(--pbas-primary); padding-left: 15px; color: var(--pbas-primary); font-weight: 700; text-transform: uppercase; }
    .save-btn { background: var(--pbas-primary) !important; text-transform: none; font-weight: 500; }
    .add-btn { color: var(--pbas-primary); font-weight: 600; cursor: pointer; }
</style>

<div class="container" style="width: 96%;">
    <div class="center-align" style="margin-bottom: 30px;">
        <h4 style="font-weight: 800; color: var(--pbas-primary);">Annual Self-Assessment PBAS Form</h4>
        <p class="grey-text">Academic Year: <b>{{year}}</b> | Status: <span class="chip">{{appraisal.status}}</span></p>
    </div>

    <h5 class="part-divider">Part I: AICTE 360 Degree Feedback</h5>
    
    <div class="card section-card">
        <div class="form-header">1.1 Teaching Process</div>
        <div class="card-content">
            <form action="/appraisal/save-teaching" method="POST">
                <table id="table1_1" class="highlight">
                    <thead><tr><th>Sem</th><th>Course</th><th>Type</th><th>Scheduled</th><th>Held</th><th>Encl No</th><th>Action</th></tr></thead>
                    <tbody>
                        {{#each appraisal.teachingProcess}}
                        <tr>
                            <td><input type="text" name="teachingProcess[{{@index}}][semester]" value="{{this.semester}}" class="table-input"></td>
                            <td><input type="text" name="teachingProcess[{{@index}}][courseName]" value="{{this.courseName}}" class="table-input"></td>
                            <td><input type="text" name="teachingProcess[{{@index}}][type]" value="{{this.type}}" class="table-input"></td>
                            <td><input type="number" name="teachingProcess[{{@index}}][scheduledClasses]" value="{{this.scheduledClasses}}" class="table-input"></td>
                            <td><input type="number" name="teachingProcess[{{@index}}][heldClasses]" value="{{this.heldClasses}}" class="table-input"></td>
                            <td><input type="text" name="teachingProcess[{{@index}}][enclosureNo]" value="{{this.enclosureNo}}" class="table-input"></td>
                            <td><i class="material-icons red-text pointer" onclick="this.closest('tr').remove()">delete</i></td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
                <div class="right-align" style="margin-top:10px;"><span class="add-btn" onclick="addRow('table1_1')">+ Add Row</span> <button type="submit" class="btn save-btn ml-2">Save 1.1</button></div>
